# .env  —  environment variables for the fraud detection system
# This file is ready to use as-is for local/demo purposes.

API_KEY=fraud-demo-key-2024
KAFKA_BROKER=kafka:29092
PORT=5000
WORKERS=3
WORKER_TIMEOUT=30
LOG_LEVEL=info
INPUT_TOPIC=transactions
OUTPUT_TOPIC=fraud.predictions
CONSUMER_GROUP=fraud-detector-v1
FLASK_API_URL=http://fraud-api:5000
REQUEST_TIMEOUT_S=2.0
MAX_RETRIES=3
